---
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { t, defaultLocale } from '@/i18n';

const cases = [
  {
    titleKey: 'home.cases.1.title',
    stack: 'Astro, TypeScript, Tailwind',
    resultKey: 'home.cases.1.result'
  },
  {
    titleKey: 'home.cases.2.title',
    stack: 'React, FastAPI, PostgreSQL',
    resultKey: 'home.cases.2.result'
  },
  {
    titleKey: 'home.cases.3.title',
    stack: 'Python, Telegram API, Redis',
    resultKey: 'home.cases.3.result'
  }
] as const;
---

<section class="container-shell py-16">
  <SectionHeading
    eyebrow={t(defaultLocale, 'home.cases.eyebrow')}
    title={t(defaultLocale, 'home.cases.title')}
    description={t(defaultLocale, 'home.cases.description')}
    eyebrowKey="home.cases.eyebrow"
    titleKey="home.cases.title"
    descriptionKey="home.cases.description"
  />

  <div class="grid gap-4 md:grid-cols-3">
    {cases.map((item) => (
      <article class="surface-card">
        <h3 class="text-lg font-semibold" data-i18n={item.titleKey}>{t(defaultLocale, item.titleKey)}</h3>
        <p class="mt-3 text-sm muted">{item.stack}</p>
        <p class="mt-4 font-medium text-[var(--accent)]" data-i18n={item.resultKey}>{t(defaultLocale, item.resultKey)}</p>
      </article>
    ))}
  </div>
</section>
