---
import SectionHeading from '@/components/ui/SectionHeading.astro';

const cases = [
  {
    title: 'SaaS marketing revamp',
    stack: 'Astro, TypeScript, Tailwind',
    result: '+38% lead conversion'
  },
  {
    title: 'Internal ops dashboard',
    stack: 'React, FastAPI, PostgreSQL',
    result: '2x faster reporting cycle'
  },
  {
    title: 'E-commerce automation bot',
    stack: 'Python, Telegram API, Redis',
    result: 'Saved 30+ hours/week'
  }
];
---

<section class="container-shell py-16">
  <SectionHeading
    eyebrow="Selected work"
    title="Cases that delivered measurable impact"
    description="A preview of recent projects across growth, product, and automation."
  />

  <div class="grid gap-4 md:grid-cols-3">
    {cases.map((item) => (
      <article class="surface-card">
        <h3 class="text-lg font-semibold">{item.title}</h3>
        <p class="mt-3 text-sm muted">{item.stack}</p>
        <p class="mt-4 font-medium text-[var(--accent)]">{item.result}</p>
      </article>
    ))}
  </div>
</section>
