---
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { t, defaultLocale } from '@/i18n';

const points = ['home.advantages.1', 'home.advantages.2', 'home.advantages.3', 'home.advantages.4'] as const;
---

<section class="container-shell py-16">
  <SectionHeading
    eyebrow={t(defaultLocale, 'home.advantages.eyebrow')}
    title={t(defaultLocale, 'home.advantages.title')}
    eyebrowKey="home.advantages.eyebrow"
    titleKey="home.advantages.title"
  />
  <ul class="grid gap-3 md:grid-cols-2">
    {points.map((key) => (
      <li class="surface-card" data-i18n={key}>{t(defaultLocale, key)}</li>
    ))}
  </ul>
</section>
