---
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { t, defaultLocale } from '@/i18n';

const services = [
  { titleKey: 'home.services.website.title', summaryKey: 'home.services.website.summary' },
  { titleKey: 'home.services.backend.title', summaryKey: 'home.services.backend.summary' },
  { titleKey: 'home.services.devops.title', summaryKey: 'home.services.devops.summary' },
  { titleKey: 'home.services.bots.title', summaryKey: 'home.services.bots.summary' }
] as const;
---

<section id="services" class="container-shell py-16">
  <SectionHeading
    eyebrow={t(defaultLocale, 'home.services.eyebrow')}
    title={t(defaultLocale, 'home.services.title')}
    description={t(defaultLocale, 'home.services.description')}
    eyebrowKey="home.services.eyebrow"
    titleKey="home.services.title"
    descriptionKey="home.services.description"
  />

  <div class="grid gap-4 md:grid-cols-2">
    {services.map((service) => (
      <article class="surface-card">
        <h3 class="text-xl font-semibold" data-i18n={service.titleKey}>{t(defaultLocale, service.titleKey)}</h3>
        <p class="mt-3 muted" data-i18n={service.summaryKey}>{t(defaultLocale, service.summaryKey)}</p>
      </article>
    ))}
  </div>
</section>
