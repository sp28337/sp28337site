---
import Button from '@/components/ui/Button.astro';
---

<section class="container-shell pt-20 pb-16 sm:pt-28">
  <div class="rounded-3xl border border-[var(--surface-border)] px-6 py-12 sm:px-10 sm:py-16" style="background: var(--hero-gradient);">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] muted">Web engineering partner</p>
    <h1 class="mt-4 max-w-3xl text-4xl font-black tracking-tight sm:text-6xl">
      Building fast, scalable web products that turn traffic into growth.
    </h1>
    <p class="mt-6 max-w-2xl text-lg muted">
      I help startups and companies launch high-performance websites, backend systems, and automation that drive real business outcomes.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <Button href="/contact">Start a project</Button>
      <Button href="/cases" variant="secondary">View case studies</Button>
    </div>
  </div>
</section>
