---
import Button from '@/components/ui/Button.astro';
import { t, defaultLocale } from '@/i18n';
---

<section class="container-shell pt-20 pb-16 sm:pt-28">
  <div class="rounded-3xl border border-[var(--surface-border)] px-6 py-12 sm:px-10 sm:py-16" style="background: var(--hero-gradient);">
    <p class="text-sm font-semibold uppercase tracking-[0.2em] muted" data-i18n="hero.eyebrow">{t(defaultLocale, 'hero.eyebrow')}</p>
    <h1 class="mt-4 max-w-3xl text-4xl font-black tracking-tight sm:text-6xl" data-i18n="hero.title">
      {t(defaultLocale, 'hero.title')}
    </h1>
    <p class="mt-6 max-w-2xl text-lg muted" data-i18n="hero.description">
      {t(defaultLocale, 'hero.description')}
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <Button href="/contact" data-i18n="hero.ctaPrimary">{t(defaultLocale, 'hero.ctaPrimary')}</Button>
      <Button href="/cases" variant="secondary" data-i18n="hero.ctaSecondary">{t(defaultLocale, 'hero.ctaSecondary')}</Button>
    </div>
  </div>
</section>
