---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  eyebrowKey?: string;
  titleKey?: string;
  descriptionKey?: string;
}

const { eyebrow, title, description, eyebrowKey, titleKey, descriptionKey } = Astro.props;
---

<header class="mb-10 max-w-2xl">
  {eyebrow && (
    <p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] muted" data-i18n={eyebrowKey}>
      {eyebrow}
    </p>
  )}
  <h2 class="text-3xl font-bold tracking-tight sm:text-4xl" data-i18n={titleKey}>{title}</h2>
  {description && <p class="mt-3 text-base muted" data-i18n={descriptionKey}>{description}</p>}
</header>
