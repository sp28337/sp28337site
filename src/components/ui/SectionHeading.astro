---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<header class="mb-10 max-w-2xl">
  {eyebrow && <p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] muted">{eyebrow}</p>}
  <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">{title}</h2>
  {description && <p class="mt-3 text-base muted">{description}</p>}
</header>
