---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary';
  type?: 'button' | 'submit';
}

const { href, variant = 'primary', type = 'button', ...attrs } = Astro.props;

const classes =
  variant === 'primary'
    ? 'inline-flex items-center rounded-xl bg-[var(--accent)] px-5 py-3 text-sm font-semibold text-white transition hover:opacity-90'
    : 'inline-flex items-center rounded-xl border border-[var(--surface-border)] bg-[var(--surface)] px-5 py-3 text-sm font-semibold text-[var(--text)] transition hover:border-[var(--accent)]';
---

{href ? <a class={classes} href={href} {...attrs}><slot /></a> : <button class={classes} type={type} {...attrs}><slot /></button>}
