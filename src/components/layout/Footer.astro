---
import { SITE } from '@/config/site';
import { t, defaultLocale } from '@/i18n';
---

<footer class="mt-20 border-t border-[var(--surface-border)]">
  <div class="container-shell flex flex-col gap-4 py-10 text-sm muted sm:flex-row sm:items-center sm:justify-between">
    <p>
      © {new Date().getFullYear()} {SITE.name}. <span data-i18n="footer.rights">{t(defaultLocale, 'footer.rights')}</span>
    </p>
    <div class="flex items-center gap-4">
      <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
      <a href={SITE.telegram} target="_blank" rel="noreferrer">Telegram</a>
    </div>
  </div>
</footer>
