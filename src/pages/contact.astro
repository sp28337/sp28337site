---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { SITE } from '@/config/site';
---

<BaseLayout
  title="Contact | sp28337"
  description="Get in touch to discuss your website, backend, DevOps, or automation project."
  pathname="/contact"
>
  <section class="container-shell py-16 sm:py-20">
    <SectionHeading
      eyebrow="Contact"
      title="Let’s discuss your project"
      description="Share your current challenges, goals, and timeline — I’ll get back with a practical plan."
    />

    <div class="grid gap-6 lg:grid-cols-2">
      <form class="surface-card space-y-4" method="post" action="/api/contact" aria-label="Contact form">
        <div>
          <label class="mb-1 block text-sm font-medium" for="name">Name</label>
          <input class="w-full rounded-lg border border-[var(--surface-border)] bg-transparent px-3 py-2" id="name" name="name" required />
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium" for="email">Email</label>
          <input
            class="w-full rounded-lg border border-[var(--surface-border)] bg-transparent px-3 py-2"
            id="email"
            name="email"
            required
            type="email"
          />
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium" for="message">Project details</label>
          <textarea
            class="min-h-32 w-full rounded-lg border border-[var(--surface-border)] bg-transparent px-3 py-2"
            id="message"
            name="message"
            required
          ></textarea>
        </div>
        <button class="inline-flex rounded-xl bg-[var(--accent)] px-5 py-3 text-sm font-semibold text-white" type="submit">
          Send inquiry
        </button>
      </form>

      <aside class="surface-card">
        <h3 class="text-lg font-semibold">Direct contacts</h3>
        <p class="mt-3 text-sm muted">Prefer a direct channel? Reach out via email or Telegram.</p>
        <ul class="mt-4 space-y-2 text-sm">
          <li>
            Email: <a class="text-[var(--accent)]" href={`mailto:${SITE.email}`}>{SITE.email}</a>
          </li>
          <li>
            Telegram: <a class="text-[var(--accent)]" href={SITE.telegram} target="_blank" rel="noreferrer">@sp28337</a>
          </li>
        </ul>
      </aside>
    </div>
  </section>
</BaseLayout>
