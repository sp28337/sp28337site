---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';

const projects = [
  {
    title: 'SaaS acquisition landing',
    description: 'Redesigned a multi-page marketing site with clear conversion funnels and rapid content editing.',
    stack: ['Astro', 'TailwindCSS', 'Cloudflare'],
    result: 'Lead-to-demo conversion improved by 38% in 6 weeks.'
  },
  {
    title: 'Fintech onboarding backend',
    description: 'Implemented FastAPI microservice for KYC onboarding and partner API synchronization.',
    stack: ['FastAPI', 'PostgreSQL', 'Docker'],
    result: 'Cut onboarding latency from minutes to seconds.'
  },
  {
    title: 'Automation support assistant',
    description: 'Built Telegram bot with smart routing for incoming client operations requests.',
    stack: ['Python', 'Telegram Bot API', 'Redis'],
    result: 'Reduced manual triage load by 45%.'
  }
];
---

<BaseLayout
  title="Cases | sp28337"
  description="Portfolio of web engineering projects with stack details and measurable business results."
  pathname="/cases"
>
  <section class="container-shell py-16 sm:py-20">
    <SectionHeading
      eyebrow="Portfolio"
      title="Selected projects"
      description="A snapshot of outcomes delivered for startups and product teams."
    />

    <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {projects.map((project) => (
        <article class="surface-card flex flex-col">
          <h3 class="text-xl font-semibold">{project.title}</h3>
          <p class="mt-3 text-sm muted">{project.description}</p>
          <p class="mt-4 text-sm"><span class="font-semibold">Stack:</span> {project.stack.join(', ')}</p>
          <p class="mt-4 font-medium text-[var(--accent)]">{project.result}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
