---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/ui/SectionHeading.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths({ paginate }) {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const sorted = allPosts.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
  return paginate(sorted, { pageSize: 6 });
}

const { page } = Astro.props;
const currentPath = `/blog/${page.currentPage}`;
---

<BaseLayout
  title="Blog | sp28337"
  description="Engineering insights on Astro, FastAPI, web performance, and scalable architecture."
  pathname={currentPath}
>
  <section class="container-shell py-16 sm:py-20">
    <SectionHeading eyebrow="Blog" title="Articles" description="Practical engineering notes from real project delivery." />
    <div class="grid gap-4 md:grid-cols-2">
      {page.data.map((post) => (
        <article class="surface-card">
          <p class="text-xs muted">{post.data.publishedAt.toLocaleDateString('en-US')}</p>
          <h2 class="mt-2 text-xl font-semibold">
            <a href={`/blog/${post.id}/`} class="hover:text-[var(--accent)]">{post.data.title}</a>
          </h2>
          <p class="mt-3 text-sm muted">{post.data.description}</p>
        </article>
      ))}
    </div>

    <nav class="mt-8 flex items-center gap-3" aria-label="Pagination">
      {page.url.prev && <a class="rounded-lg border border-[var(--surface-border)] px-4 py-2 text-sm" href={page.url.prev}>Previous</a>}
      <span class="text-sm muted">Page {page.currentPage} of {page.lastPage}</span>
      {page.url.next && <a class="rounded-lg border border-[var(--surface-border)] px-4 py-2 text-sm" href={page.url.next}>Next</a>}
    </nav>
  </section>
</BaseLayout>
